# ==========================================
# Phallo - Git Ignore Rules
# ==========================================

# Django & Python Caches
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Database (Keep schema local, don't upload dynamic database records)
*.sqlite3
*.sqlite3-journal
db.sqlite3

# Local Environment Variables
.env

# Virtual Environments
venv/
env/
.venv/
ENV/
env.bak/
venv.bak/

# Django Media Directory (Ignore local uploaded files, but keep directory structure)
media/products/*
media/banners/*
# Prevent ignoring the folder structure itself by using gitkeep if needed, or simply ignoring all files in them
!media/products/.gitkeep
!media/banners/.gitkeep

# Django Static Root & Logs
staticfiles/
*.log
local_settings.py

# IDE / Editor Files
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*~

# Operating System Files
.DS_Store
Thumbs.db
db.db
ehthumbs.db
desktop.ini
