# Phallo Environment Variables Template
# Copy this file to '.env' and configure your secret settings.

# SECURITY WARNING: keep the secret key used in production secret!
# Generate a secure key for production.
DJANGO_SECRET_KEY=your-super-secret-key-goes-here

# SECURITY WARNING: don't run with debug turned on in production!
DJANGO_DEBUG=True

# Comma-separated list of hostnames/IPs. Use '*' for development, or specify hosts.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
